{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "README.md",
    "specs/",
    ".github/instructions/common.instructions.md"
  ],
  "references": {
    "iklo": {
      "path": ".",
      "description": "Iklo language implementation (Rust workspace)"
    }
  },
  "agent": {
    "iklo": {
      "model": "opencode/big-pickle",
      "mode": "subagent",
      "description": "Expert on Iklo interpreter (lexer, parser, AST, interpreter, CLI)",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "explore": {
      "model": "opencode/big-pickle",
      "mode": "subagent",
      "description": "Fast codebase exploration and search",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "lsp": {
  },
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "edit": "ask",
    "bash": { "cargo *": "allow", "make *": "allow", "git *": "allow", "*": "ask" }
  },
  "plugin": [
    "opencode-conductor",
    "opencode-goal-plugin",
    "opencode-notificator",
    "opencode-notifier",
    "opencode-notify",
    "opencode-scheduler",
    "opencode-shell-strategy",
    "opencode-skillfull",

    // websearch-cited should be the LAST plugin. See https://github.com/ghoulr/opencode-websearch-cited
    "opencode-websearch-cited@1.2.0"
  ],
  "provider": {
    "opencode": {}
  }
}
